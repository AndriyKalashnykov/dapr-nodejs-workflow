# .env.example — committed source of truth for every operator-tunable value.
#
# Copy to `.env` (gitignored) and override as needed: `cp .env.example .env`.
# Docker Compose auto-loads `.env`; the Makefile also `-include`s it (these are
# its `?=` defaults' fallback);
# shell scripts (e2e/*, scripts) source this file then `.env`. One source of
# truth, many consumers — never hardcode any of these values elsewhere.

# ─── Network / host ───────────────────────────────────────────────────────────
HOST=localhost

# ─── Application ──────────────────────────────────────────────────────────────
PORT=3000
APP_ID=workflow-api

# ─── Dapr sidecar (standalone/self-hosted) ────────────────────────────────────
DAPR_HTTP_PORT=3500
DAPR_GRPC_PORT=50001
DAPR_SCHEDULER_PORT=50006

# ─── Datastores ───────────────────────────────────────────────────────────────
# Host-published ports (container-internal stays 5432/6379). Overriding these
# lets the stack run alongside another Postgres/Redis already holding the
# default port — `make up POSTGRES_PORT=5433` renders the same port into the
# Dapr components (see `make render-components` / `render-check`).
POSTGRES_PORT=5432
REDIS_PORT=6379
# DB credentials + name are COUPLED to the Dapr component YAML
# (components/postgres.yaml, dapr/ci/postgres.yaml) which has no {env:VAR}
# templating tag — changing them here alone would NOT reach the sidecar, so they
# are documented for reference only. Keep compose and the component in sync.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=daprrulz
POSTGRES_DB=postgres

# ─── Production-image e2e / smoke / DAST ──────────────────────────────────────
# Host port the built image binds for `make e2e` / `smoke` / `dast`.
TEST_HOST_PORT=3100

# ─── Compose healthcheck timings ──────────────────────────────────────────────
COMPOSE_HEALTHCHECK_INTERVAL=10s
COMPOSE_HEALTHCHECK_TIMEOUT=5s
COMPOSE_HEALTHCHECK_RETRIES=5

# ─── Readiness timeouts / poll cadence (seconds) ──────────────────────────────
# Outer bound each readiness wait tolerates before failing, and the poll cadence.
POSTGRES_READY_TIMEOUT=60
REDIS_READY_TIMEOUT=30
SERVER_READY_TIMEOUT=15
DAPR_READY_TIMEOUT=30
DAPR_GRPC_READY_TIMEOUT=15
# Image boot-marker poll (e2e / smoke / dast): attempts x interval.
BOOT_POLL_ATTEMPTS=30
BOOT_POLL_INTERVAL=1
# Workflow-completion wait for the full-stack e2e.
COMPLETION_TIMEOUT=60
