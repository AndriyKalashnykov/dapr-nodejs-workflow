@startuml c4-context
!include C4-PlantUML/C4_Context.puml

' Modern flat styling: no shadows, sharper corners, clean sans-serif, modern palette.
skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam roundCorner 4
skinparam defaultFontName "Inter, Helvetica, Arial, sans-serif"
skinparam defaultFontSize 13
skinparam ArrowColor #37474F
skinparam ArrowThickness 1.2
skinparam rectangleBorderThickness 1.3

UpdateElementStyle("person",    $fontColor="#FFFFFF", $bgColor="#0F766E", $borderColor="#134E4A")
UpdateElementStyle("system",     $fontColor="#FFFFFF", $bgColor="#2563EB", $borderColor="#1E3A8A")
UpdateBoundaryStyle($bgColor="#F1F5F9", $borderColor="#94A3B8", $fontColor="#1E293B")

title System Context — Dapr Node.js Workflow

Person(user, "API Consumer", "HTTP client calling REST endpoints")
System(sys, "Dapr Node.js Workflow", "Durable workflow service: schedules workflows that query Postgres via a Dapr binding, with Redis-backed state for crash-safe replay")

Rel(user, sys, "Schedules and polls workflows", "HTTPS / JSON")

SHOW_LEGEND()
@enduml
