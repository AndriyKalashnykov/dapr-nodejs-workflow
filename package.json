{
  "name": "dapr-nodejs-workflow",
  "version": "1.0.0",
  "description": "Dapr JS-SDK to author workflow",
  "private": "true",
  "engines": {
    "node": ">=24.14.1",
    "pnpm": ">=10.33.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsc --outDir ./dist/",
    "start:api-server": "pnpm run build && node dist/api-server.js",
    "start:dapr:api-server": "DAPR_HOST=localhost DAPR_HTTP_PORT=3500 dapr run --app-id workflow-api --app-port 3000 --app-protocol http --dapr-grpc-port 50001 --dapr-http-port 3500 --scheduler-host-address localhost:50006 --resources-path ./components -- node dist/api-server.js"
  },
  "author": "Andriy Kalashnykov",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "24.12.2",
    "@types/supertest": "7.2.0",
    "eslint": "10.2.0",
    "prettier": "3.8.2",
    "supertest": "7.2.2",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  },
  "dependencies": {
    "@dapr/dapr": "^3.6.1",
    "axios": "^1.15.0",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp": ">=8.4.0",
      "follow-redirects": ">=1.16.0"
    },
    "onlyBuiltDependencies": [
      "protobufjs"
    ]
  }
}
